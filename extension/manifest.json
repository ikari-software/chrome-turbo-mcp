{
  "manifest_version": 3,
  "name": "TurboWeb MCP by ikari",
  "version": "1.0.0",
  "description": "TurboWeb MCP by ikari — fast browser control over MCP (screenshots, DOM OCR, spatial awareness, on-page agent cursor)",
  "author": "Cezar Pokorski (ikari)",
  "homepage_url": "https://github.com/ikari-software/turboweb-mcp",
  "icons": {
    "16": "icons/app-icon-16.png",
    "32": "icons/app-icon-32.png",
    "48": "icons/app-icon-48.png",
    "128": "icons/app-icon-128.png"
  },
  "permissions": ["tabs", "activeTab", "scripting", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TurboWeb MCP by ikari",
    "default_icon": {
      "16": "icons/app-icon-16.png",
      "32": "icons/app-icon-32.png",
      "48": "icons/app-icon-48.png",
      "128": "icons/app-icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
