{
  "manifest_version": 3,
  "name": "Chrome Turbo MCP",
  "version": "1.0.0",
  "description": "Turbo browser control via MCP — fast screenshots, DOM OCR, spatial awareness",
  "permissions": ["tabs", "activeTab", "scripting", "debugger", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Turbo MCP"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
